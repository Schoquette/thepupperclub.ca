<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Stop IIS from answering OPTIONS requests itself so CORS preflights
         reach Laravel and pick up its Access-Control-* headers. Without
         this, IIS short-circuits OPTIONS with a no-CORS Allow header and
         the browser blocks the actual POST as a CORS violation. -->
    <handlers>
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="API Passthrough" stopProcessing="true">
          <match url="^api/(.*)$" />
          <action type="Rewrite" url="api/public/index.php/{R:1}" />
        </rule>
        <rule name="SPA and Marketing Routes" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/fallback.php" />
        </rule>
      </rules>
    </rewrite>
    <httpErrors errorMode="Custom">
      <remove statusCode="404" />
      <error statusCode="404" path="/fallback.php" responseMode="ExecuteURL" />
    </httpErrors>
  </system.webServer>
</configuration>
