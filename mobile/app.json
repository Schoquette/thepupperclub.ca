{
  "expo": {
    "name": "The Pupper Club",
    "slug": "the-pupper-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6F3EE"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.thepupperclub.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F6F3EE"
      },
      "package": "ca.thepupperclub.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A24D"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "pupperclub"
  }
}
