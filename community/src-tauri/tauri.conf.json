{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The Pupper Club Community",
  "version": "0.1.0",
  "identifier": "ca.thepupperclub.community",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "The Pupper Club Community",
        "width": 1080,
        "height": 720,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#F6F3EE"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "shortDescription": "Trusted neighbourhood pet care.",
    "longDescription": "A small, trusted circle of verified neighbours who show up for each other — and for the pets they love."
  }
}
